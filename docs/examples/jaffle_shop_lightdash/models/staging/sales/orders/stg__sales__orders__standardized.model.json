{
    "type": "stg_select_source",
    "group": "sales",
    "topic": "orders",
    "name": "standardized",
    "materialized": "ephemeral",
    "from": {
        "source": "development__jaffle_shop_lightdash_dev_seeds.raw_orders"
    },
    "select": [
        {
            "name": "order_id",
            "expr": "id",
            "type": "dim",
            "description": "Unique identifier for each order",
            "lightdash": {
                "dimension": {
                    "group_label": "Order Fields",
                    "label": "Order ID"
                }
            }
        },
        {
            "name": "customer_id",
            "expr": "customer",
            "type": "dim",
            "description": "Foreign key to customer",
            "lightdash": {
                "dimension": {
                    "group_label": "Customer Fields",
                    "label": "Customer ID"
                }
            }
        },
        {
            "name": "store_id",
            "expr": "store_id",
            "type": "dim",
            "description": "Foreign key to store",
            "lightdash": {
                "dimension": {
                    "group_label": "Store Fields",
                    "label": "Store ID"
                }
            }
        },
        {
            "name": "ordered_at",
            "expr": "CAST(ordered_at AS TIMESTAMP)",
            "type": "dim",
            "description": "Timestamp when order was placed",
            "lightdash": {
                "dimension": {
                    "group_label": "Order Fields",
                    "label": "Ordered At",
                    "type": "timestamp"
                }
            }
        },
        {
            "name": "order_date",
            "expr": "DATE(CAST(ordered_at AS TIMESTAMP))",
            "type": "dim",
            "description": "Date when order was placed",
            "lightdash": {
                "dimension": {
                    "group_label": "Order Fields",
                    "label": "Order Date",
                    "type": "date"
                }
            }
        },
        {
            "name": "subtotal_cents",
            "expr": "subtotal",
            "type": "fct",
            "description": "Order subtotal in cents",
            "lightdash": {
                "dimension": {
                    "group_label": "Order Fields",
                    "label": "Order Subtotal (in cents)",
                    "type": "number"
                }
            }
        },
        {
            "name": "tax_paid_cents",
            "expr": "tax_paid",
            "type": "fct",
            "description": "Tax amount paid in cents",
            "lightdash": {
                "dimension": {
                    "group_label": "Order Fields",
                    "label": "Tax Paid (in cents)",
                    "type": "number"
                }
            }
        },
        {
            "name": "order_total_cents",
            "expr": "order_total",
            "type": "fct",
            "description": "Total order amount in cents",
            "lightdash": {
                "dimension": {
                    "group_label": "Order Fields",
                    "label": "Order Total (in cents)",
                    "type": "number"
                }
            }
        }
    ]
}