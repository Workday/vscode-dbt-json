{
  "$id": "model.group_by.schema.json",
  "title": "Schema Model Group By",
  "description": "Validate model group by",
  "type": "array",
  "minItems": 1,
  "items": {
    "anyOf": [
      { "type": "string", "pattern": "^([A-z]|[0-9]|\\.|_)+$" },
      {
        "type": "object",
        "additionalProperties": false,
        "required": ["expr"],
        "properties": { "expr": { "type": "string" } }
      },
      {
        "type": "object",
        "additionalProperties": false,
        "required": ["type"],
        "properties": { "type": { "const": "dims" } }
      }
    ]
  }
}
