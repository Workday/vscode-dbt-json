{
  "$id": "model.incremental_strategy.schema.json",
  "description": "Incremental Strategy",
  "anyOf": [
    {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": { "const": "delete+insert" },
        "unique_key": {
          "description": "Override the unique key(s) to use for merging",
          "anyOf": [
            { "type": "string" },
            {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string" }
            }
          ]
        }
      }
    },
    {
      "type": "object",
      "required": ["type", "unique_key"],
      "properties": {
        "type": { "const": "merge" },
        "unique_key": {
          "description": "The unique key(s) to use for merging",
          "anyOf": [
            { "type": "string" },
            {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string" }
            }
          ]
        },
        "merge_exclude_columns": {
          "description": "The columns to exclude when merging",
          "type": "array",
          "items": { "type": "string" }
        },
        "merge_update_columns": {
          "description": "The columns to update when merging",
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  ]
}
