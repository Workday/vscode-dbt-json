{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Extension",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "args": ["--extensionDevelopmentPath=${workspaceFolder}"],
      "outFiles": ["${workspaceFolder}/dist/**/*.js"],
      "preLaunchTask": "${defaultBuildTask}",
      "env": {
        "CODER_WORKSPACE_OWNER": "${env:CODER_WORKSPACE_OWNER}",
        "LIGHTDASH_PREVIEW_NAME": "${env:LIGHTDASH_PREVIEW_NAME}"
      }
    }
  ]
}
